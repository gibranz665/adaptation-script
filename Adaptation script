local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ContentProvider = game:GetService("ContentProvider")
local Player = Players.LocalPlayer

local route = {}
local isRecalling = false
local recallSpeed = 4 

-- [[ ASSET CONFIG ]] --
local RAW_ID = "106059071384886" 
local WHEEL_ID = "https://www.roblox.com/asset-thumbnail/image?assetId=" .. RAW_ID .. "&width=420&height=420&format=png"
local SOUND_ID = "rbxassetid://130081290814025"

-- [[ UI CONSTRUCTION ]] --
local screenGui = Instance.new("ScreenGui", gethui())
screenGui.Name = "KSFI_MAHORAGA_V12"
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = 999

local Frame = Instance.new("Frame", screenGui)
Frame.Size = UDim2.new(0, 240, 0, 80)
Frame.Position = UDim2.new(0, 20, 1, -130)
Frame.BorderSizePixel = 0 
Frame.Active = true
Frame.Draggable = true 
Instance.new("UICorner", Frame).CornerRadius = UDim.new(0, 8)

-- [[ RGB LOGIC ]] --
RunService.RenderStepped:Connect(function()
    local t = tick() * 3 
    local hue = (math.sin(t) + 1) / 2 * 0.4 + 0.6 
    if hue > 1 then hue = hue - 1 end
    Frame.BackgroundColor3 = Color3.fromHSV(hue, 0.8, 0.4) 
end)

-- [[ WHEEL SETUP ]] --
local Wheel = Instance.new("ImageLabel")
Wheel.Name = "MahoragaWheel"
Wheel.Parent = screenGui 
Wheel.Size = UDim2.new(0, 280, 0, 280) 
Wheel.Position = UDim2.new(0.5, -140, 0.5, -140) 
Wheel.BackgroundTransparency = 1 
Wheel.Image = WHEEL_ID
Wheel.ImageColor3 = Color3.new(1, 1, 1)
Wheel.ScaleType = Enum.ScaleType.Fit
Wheel.ZIndex = 1000
Wheel.Visible = false

task.spawn(function()
    ContentProvider:PreloadAsync({Wheel})
end)

-- [[ BUTTONS ]] --
local On = Instance.new("TextButton", Frame)
On.Size = UDim2.new(0, 110, 0, 50)
On.Position = UDim2.new(0, 7, 0.5, -25)
On.BackgroundColor3 = Color3.fromRGB(0, 0, 0) 

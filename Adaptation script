Off.Position = UDim2.new(1, -117, 0.5, -25)
Off.BackgroundColor3 = Color3.fromRGB(0, 80, 200) 
Off.Text = "Readaptation"
Off.TextColor3 = Color3.new(1,1,1)
Off.Font = Enum.Font.GothamBold
Off.TextSize = 13
Off.ZIndex = 500
Instance.new("UICorner", Off)

-- [[ RECALL LOGIC ]] --
local function PlayAdaptEffect()
    Wheel.Visible = true
    
    local s = Instance.new("Sound", game:GetService("SoundService"))
    s.SoundId = SOUND_ID; s.Volume = 3; s:Play()
    game:GetService("Debris"):AddItem(s, 2)
    
    task.spawn(function()
        local startTime = tick()
        -- Muncul hanya 1.5 detik (di antara 1-2 detik)
        while Wheel.Visible and (tick() - startTime) < 1.5 do
            -- Kecepatan dikurangi 7 (19 - 7 = 12)
            Wheel.Rotation = Wheel.Rotation + 12 
            task.wait()
        end
        Wheel.Visible = false 
    end)
end

On.MouseButton1Click:Connect(function()
    if isRecalling or #route == 0 then return end
    isRecalling = true
    PlayAdaptEffect()

    On.Text = "X"
    On.BackgroundColor3 = Color3.fromRGB(40, 40, 40) 

    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    
    if root and hum then
        hum.PlatformStand = true 
        while #route > 0 and isRecalling do
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
            root.CFrame = route[#route]
            for i = 1, recallSpeed do
                if #route > 0 then table.remove(route, #route) end
            end
            RunService.Heartbeat:Wait()
        end
        isRecalling = false
        hum.PlatformStand = false
        On.Text = "✧adaptation✧"
        On.BackgroundColor3 = Color3.fromRGB(0, 0, 0) 
        Wheel.Visible = false
    end
end)

Off.MouseButton1Click:Connect(function()
    isRecalling = false
    Wheel.Visible = false
    On.Text = "✧adaptation✧"
    On.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
end)

-- Record Route
RunService.Heartbeat:Connect(function()
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if root and not isRecalling then
        table.insert(route, root.CFrame)
        if #route > 600 then table.remove(route, 1) end
    end
end)
